{
  "name": "@getrheo/renderer-core",
  "version": "2.0.3",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node ../../scripts/build-publishable-package.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@getrheo/contracts": "2.0.3",
    "@getrheo/flow-runtime": "2.0.3"
  },
  "devDependencies": {
    "@rheo/config": "workspace:*",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "homepage": "https://docs.getrheo.io/docs/developer-guide/sdk",
  "description": "Layer rendering decisions for Rheo flows (transitive dependency).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getrheo/rheo-js.git",
    "directory": "packages/renderer-core"
  },
  "bugs": {
    "url": "https://github.com/getrheo/rheo-js/issues"
  }
}
