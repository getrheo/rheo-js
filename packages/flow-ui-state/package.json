{
  "name": "@getrheo/flow-ui-state",
  "version": "2.3.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./draft": "./src/screenInputDraft.tsx",
    "./checkbox": "./src/screenCheckboxAck.tsx"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node ../../scripts/build-publishable-package.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@getrheo/contracts": "2.3.0",
    "@getrheo/flow-runtime": "2.3.0"
  },
  "devDependencies": {
    "@rheo/config": "workspace:*",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./draft": {
        "types": "./dist/screenInputDraft.d.ts",
        "import": "./dist/screenInputDraft.js",
        "default": "./dist/screenInputDraft.js"
      },
      "./checkbox": {
        "types": "./dist/screenCheckboxAck.d.ts",
        "import": "./dist/screenCheckboxAck.js",
        "default": "./dist/screenCheckboxAck.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "homepage": "https://docs.getrheo.io/docs/developer-guide/sdk",
  "description": "React flow UI state for the Rheo SDK (transitive dependency).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getrheo/rheo-js.git",
    "directory": "packages/flow-ui-state"
  },
  "bugs": {
    "url": "https://github.com/getrheo/rheo-js/issues"
  }
}
